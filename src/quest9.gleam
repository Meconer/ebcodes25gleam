import gleam/dict
import gleam/int
import gleam/list.{Continue, Stop}
import gleam/result
import gleam/set
import gleam/string
import utils

pub fn q9p1(inp: String) {
  let dragon_ducks =
    inp
    |> string.split("\n")
    |> list.map(fn(line) {
      let parts = string.split(line, ":")
      let number =
        utils.unsafe_list_first(parts)
        |> utils.unsafe_int_parse()
      let dna = utils.unsafe_list_last(parts) |> string.to_graphemes()
      #(number, dna)
    })
    |> dict.from_list()
  let child = get_child(dragon_ducks)
  calc_result_p1(dragon_ducks, child)
}

fn calc_result_p1(dragon_ducks: dict.Dict(Int, List(String)), child_idx: Int) {
  let parents = parent_list(child_idx)
  let child_dna = dict.get(dragon_ducks, child_idx) |> result.unwrap([])
  let parent_matches =
    list.map(parents, fn(parent_idx) {
      let parent_dna = dict.get(dragon_ducks, parent_idx) |> result.unwrap([])
      list.map2(child_dna, parent_dna, fn(c, p) {
        case c == p {
          True -> 1
          False -> 0
        }
      })
      |> list.count(fn(match) { match == 1 })
    })
  list.fold(parent_matches, 1, fn(acc, mc) { acc * mc })
}

fn parent_list(child_idx: Int) {
  case child_idx {
    1 -> [2, 3]
    2 -> [1, 3]
    3 -> [1, 2]
    _ -> panic as "child can only be 1, 2 or 3"
  }
}

fn is_valid_child(child_idx, dragon_ducks) {
  let parents = parent_list(child_idx)
  let child_dna = dict.get(dragon_ducks, child_idx) |> result.unwrap([])
  let parents_dna =
    list.map(parents, fn(p_idx) {
      dict.get(dragon_ducks, p_idx) |> result.unwrap([])
    })
  rec_check_parents_and_childs(child_dna, parents_dna)
}

fn rec_check_parents_and_childs(
  child_dna: List(String),
  parents_dna: List(List(String)),
) {
  case child_dna, parents_dna {
    // If we reach the end of the child's DNA, it's valid!
    [], _ -> True

    // Pattern match to get the head of the child and both parents at once
    [c, ..c_rest], [[p1, ..p1_rest], [p2, ..p2_rest]] -> {
      case dna_check(p1, p2, c) {
        True -> rec_check_parents_and_childs(c_rest, [p1_rest, p2_rest])
        False -> False
      }
    }

    // Safety catch-all (e.g. if DNA lengths don't match)
    _, _ -> False
  }
}

fn dna_check(
  p1_dna_seq: String,
  p2_dna_seq: String,
  child_dna_seq: String,
) -> Bool {
  let parents_are_equal = p1_dna_seq == p2_dna_seq
  case parents_are_equal {
    True -> p1_dna_seq == child_dna_seq
    False -> p1_dna_seq == child_dna_seq || p2_dna_seq == child_dna_seq
  }
}

fn get_child(dragon_ducks: dict.Dict(Int, List(String))) -> Int {
  list.range(1, 3)
  |> list.fold_until(0, fn(acc, child_idx) {
    case is_valid_child(child_idx, dragon_ducks) {
      True -> Stop(child_idx)
      False -> Continue(acc)
    }
  })
}

fn calc_result_p2(
  dragon_ducks: dict.Dict(Int, List(String)),
  parent_idxs: List(Int),
  child_idx: Int,
) {
  let child_dna = dict.get(dragon_ducks, child_idx) |> result.unwrap([])
  let parent_matches =
    list.map(parent_idxs, fn(parent_idx) {
      let parent_dna = dict.get(dragon_ducks, parent_idx) |> result.unwrap([])
      list.map2(child_dna, parent_dna, fn(c, p) {
        case c == p {
          True -> 1
          False -> 0
        }
      })
      |> list.count(fn(match) { match == 1 })
    })
  list.fold(parent_matches, 1, fn(acc, mc) { acc * mc })
}

pub fn q9p2(inp: String) {
  let dragon_ducks =
    inp
    |> string.split("\n")
    |> list.map(fn(line) {
      let parts = string.split(line, ":")
      let number =
        utils.unsafe_list_first(parts)
        |> utils.unsafe_int_parse()
      let dna = utils.unsafe_list_last(parts) |> string.to_graphemes()
      #(number, dna)
    })
    |> dict.from_list()
  let duck_idx_list = list.range(1, dict.size(dragon_ducks))
  get_parents(duck_idx_list, dragon_ducks)
  |> list.flatten()
  |> list.map(fn(combo) {
    let #(child, parents) = combo
    calc_result_p2(dragon_ducks, parents, child)
  })
  |> list.fold(0, fn(acc, el) { acc + el })
}

fn get_parents(
  duck_idx_list: List(Int),
  dragon_ducks: dict.Dict(Int, List(String)),
) {
  list.fold(duck_idx_list, [], fn(acc, child_idx) {
    let possible_parents = list.filter(duck_idx_list, fn(i) { i != child_idx })
    let parent_combos = list.combination_pairs(possible_parents)
    let combos =
      list.fold(parent_combos, [], fn(acc, parents) {
        let #(p1, p2) = parents
        case is_valid_child_parents_combo(child_idx, [p1, p2], dragon_ducks) {
          True -> [#(child_idx, [p1, p2]), ..acc]
          False -> acc
        }
      })
    [combos, ..acc]
  })
}

fn is_valid_child_parents_combo(
  child_idx: Int,
  parents: List(Int),
  dragon_ducks: dict.Dict(Int, List(String)),
) -> Bool {
  let child_dna = dict.get(dragon_ducks, child_idx) |> result.unwrap([])
  let parents_dna =
    list.map(parents, fn(parent) {
      dict.get(dragon_ducks, parent) |> result.unwrap([])
    })
  rec_check_parents_and_childs(child_dna, parents_dna)
}

pub fn q9p3(inp: String) {
  let dragon_ducks =
    inp
    |> string.split("\n")
    |> list.map(fn(line) {
      let parts = string.split(line, ":")
      let number =
        utils.unsafe_list_first(parts)
        |> utils.unsafe_int_parse()
      let dna = utils.unsafe_list_last(parts) |> string.to_graphemes()
      #(number, dna)
    })
    |> dict.from_list()
  let duck_idx_list = list.range(1, dict.size(dragon_ducks))
  let cp_combos =
    get_parents(duck_idx_list, dragon_ducks)
    |> list.flatten()
    |> list.map(fn(cp) {
      let #(child, pl) = cp
      let family_set = set.from_list(pl)
      set.insert(family_set, child)
    })
  combine(cp_combos, [])
  |> list.sort(by: fn(a, b) { int.compare(set.size(b), set.size(a)) })
  |> list.first()
  |> result.unwrap(set.new())
  |> calc_result_p3()
}

fn calc_result_p3(family: set.Set(Int)) {
  set.fold(family, 0, fn(acc, num) { acc + num })
}

fn get_families(f1: set.Set(Int), f_list: List(set.Set(Int))) {
  let #(family, rejected) =
    list.fold(f_list, #(f1, []), fn(acc, f) {
      let #(f_acc, not_conn) = acc
      case set.is_disjoint(f_acc, f) {
        False -> #(set.union(f_acc, f), not_conn)
        True -> #(f_acc, [f, ..not_conn])
      }
    })

  // If the family size changed, we might have unlocked new connections 
  // in the 'not_connected' list. We must check again!
  case set.size(family) == set.size(f1) {
    True -> #(family, rejected)
    False -> get_families(family, rejected)
  }
}

fn combine(
  cp_combos: List(set.Set(Int)),
  acc: List(set.Set(Int)),
) -> List(set.Set(Int)) {
  case cp_combos {
    [] -> acc
    [f1, ..rest] -> {
      let #(f1_set, unconnecteds) = get_families(f1, rest)
      combine(unconnecteds, [f1_set, ..acc])
    }
  }
}


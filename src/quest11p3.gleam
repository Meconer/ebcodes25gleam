import gleam/int
import gleam/list
import gleam/result
import gleam/string

pub fn quest(inp: String) {
  let ducks =
    inp
    |> string.split("\n")
    |> list.map(fn(ds) { int.parse(ds) |> result.unwrap(0) })
  list.window(ducks, 2)
  |> list.all(fn(lst) {
    case lst {
      [a, b] if a > b -> False
      [a, b] if a <= b -> True
      _ -> panic as "only pair"
    }
  })
  |> echo
  0
}

